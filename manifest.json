{
  "id": "tedi.secondary-folder-tree",
  "name": "Secondary Folder Tree",
  "version": "0.1.5",
  "description": "A second folder tree on the right of TEDI's workspace. Pick any folder, click to open files in a tab, drag files into a terminal to insert the path. Rebindable shortcut: Ctrl+Shift+E.",
  "author": "IlhamRiski - ilhamriski.com",
  "homepage": "https://github.com/IlhamriSKY/TEDI.secondary-folder-tree",
  "icon": "logo.png",
  "main": "extension.js",
  "permissions": [
    "panels:register"
  ],
  "contributes": {
    "commands": [
      {
        "id": "tedi.secondary-folder-tree.toggle",
        "title": "Toggle Secondary Folder",
        "category": "Secondary Folder Tree"
      }
    ],
    "keybindings": [
      {
        "command": "tedi.secondary-folder-tree.toggle",
        "key": "Mod+Shift+E"
      }
    ],
    "panels": [
      {
        "id": "tree",
        "title": "Secondary Folder",
        "surface": "right",
        "icon": "logo.png",
        "defaultOpen": false,
        "toggleCommand": "tedi.secondary-folder-tree.toggle",
        "hideHostHeader": true
      }
    ]
  },
  "engines": { "tedi": ">=0.2.15" }
}
